---
import Layout from '../layouts/Layout.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import Background from './Background.astro';
import LainBeloved from './LainBeloved.astro';
import Posts from './Posts.astro'
---

<Layout title="lainpilled">
	<div class="content">
	<Header/>
	<Background>
		<section>
			<h2>This is my journal as I build the online schitzo-lair that is this website.</h2>
			<p>This main page is dedicated to providing updates on the website for anyone who visits to see. It is a great way for me to document my progress as well.
			</p>
			<p>This website is a passion project of mine and just contains stuff that I think is cool or I am interested in.</p>
			<p>I am a university student in Washington State.
			</p>
		</section>

		<h2>Posts</h2>

		<Posts/>
		
		<LainBeloved/>
	</Background>
	<Footer/>
	</div>
</Layout>

<style>
	h2{
		text-align: center;
		font-size: xxx-large;
		background-color: rgba(70,100,150,0.1);
	}
	section{
		text-align: center;
		h2{
			font-size: x-large;
			color: aliceblue;
			text-wrap: balance;
		}
		p{
			
			color: aliceblue;
			font-size: medium;
			font-style: oblique;
			margin-block:1.2rem;
			text-wrap:balance;
		}	
	}
	.content{
		justify-content: space-between;
		display: flex;
		flex-direction: column;
		min-height: 100%;
	}
	
</style>
